# SkillSwap+ Backend Environment
#
# Copy this file to server/.env for local development.
# Do not commit real secrets.
#
# ASEP uses MongoDB multi-document transactions for booking escrow.
# MONGODB_URI must point to MongoDB Atlas, mongos, or a replica set.
# A standalone local MongoDB URI will fail by design when
# REQUIRE_TRANSACTION_DB=true.

NODE_ENV=development
PORT=5000

# Preferred: MongoDB Atlas M0+ connection string.
# Example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/skillswap?retryWrites=true&w=majority&appName=ASEP

# Local development replica set example:
# MONGODB_URI=mongodb://127.0.0.1:27017/skillswap?replicaSet=rs0
MONGODB_URI=

# Keep true so escrow transactions cannot accidentally run on standalone MongoDB.
REQUIRE_TRANSACTION_DB=true
DB_CONNECT_RETRIES=3
DB_CONNECT_RETRY_DELAY_MS=1500

# Generate unique secrets for every environment.
# Production secrets must be at least 32 characters and must not reuse examples.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Local same-site cookies can use lax/false. Cross-domain HTTPS deployments
# such as Vercel + Render usually need COOKIE_SAMESITE=none and COOKIE_SECURE=true.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

DEFAULT_CREDITS=10
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=2097152
JSON_LIMIT=25kb
# CORS allowlist. Comma-separated values are supported.
# Development: http://localhost:5173
# Docker demo: http://localhost:8080
# Production: https://your-vercel-app.vercel.app
CLIENT_URL=http://localhost:5173

# Optional Google OAuth client ID.
GOOGLE_CLIENT_ID=

# Meeting links.
JITSI_BASE_URL=https://meet.jit.si
JITSI_ROOM_PREFIX=skillswap
