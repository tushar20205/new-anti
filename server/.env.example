# ═══════════════════════════════════════════
# SkillSwap+ Backend — Environment Variables
# ═══════════════════════════════════════════

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb://localhost:27017/skillswap

# JWT Secrets (CHANGE THESE IN PRODUCTION)
JWT_SECRET=skillswap-jwt-secret-change-me-in-production
JWT_REFRESH_SECRET=skillswap-refresh-secret-change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Credits
DEFAULT_CREDITS=10

# File Uploads
UPLOAD_DIR=./uploads

# Client URL (CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth (add your Client ID here)
GOOGLE_CLIENT_ID= 361305773230-ddge1i8uhoujgo6sh5arvas7bpm0mihr.apps.googleusercontent.com