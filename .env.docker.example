# Copy to .env.docker before running docker compose.
# Do not commit the real .env.docker file.
# This file is for local production-style validation with Docker Compose.

NODE_ENV=production
PORT=5000
# The Docker stack starts MongoDB as a single-node replica set.
MONGODB_URI=mongodb://mongo:27017/skillswap?replicaSet=rs0&directConnection=true

# Comma-separated CORS origins. Include any deployed frontend you want to test.
CLIENT_URL=http://localhost:8080
UPLOAD_DIR=/app/uploads

# Replace both secrets before running anything beyond a local demo.
JWT_SECRET=replace-with-a-unique-32-plus-character-access-token-secret
JWT_REFRESH_SECRET=replace-with-a-unique-32-plus-character-refresh-token-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Local Docker uses HTTP, so secure cookies are disabled here.
# For HTTPS production, use COOKIE_SECURE=true and usually COOKIE_SAMESITE=none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
DEFAULT_CREDITS=10
REQUIRE_TRANSACTION_DB=true
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_MS=2000
UPLOAD_MAX_BYTES=2097152
JSON_LIMIT=25kb
GOOGLE_CLIENT_ID=
JITSI_BASE_URL=https://meet.jit.si
JITSI_ROOM_PREFIX=skillswap
